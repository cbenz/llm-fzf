#!/usr/bin/env bash

STATE_DIR="${XDG_RUNTIME_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}}/llm-dictate"
REC_FILE="$STATE_DIR/llm-dictate.wav"
REC_PIDFILE="$STATE_DIR/arecord.pid"
WORKER_PIDFILE="$STATE_DIR/worker.pid"
SPINNER_PIDFILE="$STATE_DIR/spinner.pid"
NOTIFY_IDFILE="$STATE_DIR/notification.id"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

mkdir -p "$STATE_DIR"

# shellcheck source=./llm-desktop-shared.sh
source "$SCRIPT_DIR/llm-desktop-shared.sh"
notify_init "llm-dictate" "$NOTIFY_IDFILE"

is_running_pidfile() {
    local pidfile="$1"

    if [ ! -f "$pidfile" ]; then
        return 1
    fi

    kill -0 "$(cat "$pidfile")" 2>/dev/null
}

recording_active() {
    if is_running_pidfile "$REC_PIDFILE"; then
        return 0
    fi

    rm -f "$REC_PIDFILE"
    return 1
}

kill_from_pidfile() {
    local pidfile="$1"
    local signal="$2"

    if is_running_pidfile "$pidfile"; then
        kill "$signal" "$(cat "$pidfile")" 2>/dev/null
    fi

    rm -f "$pidfile"
}

stop_spinner_with_pidfile() {
    if [ -z "${SPINNER_PID:-}" ] && [ -f "$SPINNER_PIDFILE" ]; then
        SPINNER_PID="$(cat "$SPINNER_PIDFILE")"
    fi
    stop_spinner
    rm -f "$SPINNER_PIDFILE"
}

start_spinner_with_pidfile() {
    start_spinner "$1"
    if [ -n "${SPINNER_PID:-}" ]; then
        printf '%s' "$SPINNER_PID" > "$SPINNER_PIDFILE"
    fi
}

start() {
    rm -f "$REC_FILE"

    start_spinner_with_pidfile "🎤 Recording"

    arecord -f S16_LE -r 16000 -c 1 -t wav "$REC_FILE" &
    echo $! > "$REC_PIDFILE"

    (
        local transcript
        local transcribe_err_file
        local transcribe_err_msg
        local had_error=0

        cleanup_worker() {
            [ -n "${transcribe_err_file:-}" ] && rm -f "$transcribe_err_file"
            rm -f "$REC_FILE"
            stop_spinner_with_pidfile
        }
        trap cleanup_worker EXIT

        # Wait for recording to finish
        while is_running_pidfile "$REC_PIDFILE"; do
            sleep 0.1
        done

        start_spinner_with_pidfile "⏳ Transcribing"

        transcribe_err_file="$(mktemp "$STATE_DIR/transcribe.XXXXXX.err")"

        if transcript="$(llm groq-whisper - < "$REC_FILE" 2>"$transcribe_err_file")"; then
            if [ -n "$transcript" ]; then
                clipboard_paste_via_shift_insert "$transcript"
            fi
        else
            had_error=1
            stop_spinner_with_pidfile
            transcribe_err_msg="$(format_error_message "$(cat "$transcribe_err_file")")"
            notify_message "❌ Transcription failed: $transcribe_err_msg" 6000
        fi

        rm -f "$transcribe_err_file"
        stop_spinner_with_pidfile
        if [ "$had_error" -eq 0 ]; then
            close_notification
        fi
        rm -f "$WORKER_PIDFILE"
    ) &
    echo $! > "$WORKER_PIDFILE"
}

stop() {
    if recording_active; then
        kill_from_pidfile "$REC_PIDFILE" -INT
    fi
}

cancel() {
    if ! recording_active; then
        echo "No recording in progress"
        return 0
    fi

    kill_from_pidfile "$WORKER_PIDFILE" -TERM
    kill_from_pidfile "$REC_PIDFILE" -INT
    stop_spinner_with_pidfile
    notify_message "🛑 Recording cancelled" 1000
    (sleep 1; close_notification) & disown
}

toggle() {
    if recording_active; then
        stop
    else
        start
    fi
}

status() {
    if recording_active || is_running_pidfile "$WORKER_PIDFILE"; then
        echo "working"
    else
        echo "idle"
    fi
}

usage() {
    cat <<'EOF'
Usage: llm-dictate <command>

Commands:
  start   Start recording
  stop    Stop recording and transcribe
  cancel  Cancel recording
  toggle  Start if idle, stop if recording
  status  Show status (idle or working)
EOF
}

if ! require_commands arecord llm xdotool dunstify; then
    dunstify --app-name="llm-dictate" -t 6000 "❌ Missing dependencies" >/dev/null 2>&1 || true
    printf 'Install the missing commands and retry.\n' >&2
    exit 1
fi

if ! detect_clipboard_tool; then
    printf 'Missing dependencies: xclip or xsel\n' >&2
    dunstify --app-name="llm-dictate" -t 6000 "❌ Missing dependencies: xclip or xsel" >/dev/null 2>&1 || true
    printf 'Install xclip or xsel and retry.\n' >&2
    exit 1
fi

command=""

while [ "$#" -gt 0 ]; do
    case "$1" in
        start|stop|cancel|toggle|status)
            if [ -n "$command" ]; then
                echo "Only one command can be provided" >&2
                exit 1
            fi
            command="$1"
            ;;
        -h|--help|help)
            command="help"
            ;;
        *)
            echo "Unknown argument: $1" >&2
            usage
            exit 1
            ;;
    esac
    shift
done

case "$command" in
    start)
        start
        ;;
    stop)
        stop
        ;;
    cancel)
        cancel
        ;;
    toggle)
        toggle
        ;;
    status)
        status
        ;;
    ""|help)
        usage
        ;;
    *)
        usage
        exit 1
        ;;
esac
