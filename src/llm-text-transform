#!/usr/bin/env bash

set -euo pipefail

PROMPT_DIR="${LLM_FZF_PROMPT_DIR:-$HOME/.agents/prompts/desktop}"
STATE_DIR="${XDG_RUNTIME_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}}/llm-text-transform"
LOCK_FILE="$STATE_DIR/llm-text-transform.lock"
NOTIFY_IDFILE="$STATE_DIR/notification.id"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

mkdir -p "$STATE_DIR"

# shellcheck source=./llm-desktop-shared.sh
source "$SCRIPT_DIR/llm-desktop-shared.sh"
notify_init "llm-text-transform" "$NOTIFY_IDFILE"

if ! require_commands llm dunstify flock find sed sort cat xterm fzf xdotool; then
  notify_message "❌ Missing dependencies" 5000 || true
  exit 1
fi

if ! detect_clipboard_tool; then
  notify_message "❌ Missing dependencies: xclip or xsel" 5000 || true
  echo "Error: no clipboard tool found. Install xclip or xsel." >&2
  exit 1
fi

exec 9>"$LOCK_FILE"
trap 'rm -f "$LOCK_FILE"' EXIT
if ! flock -n 9; then
  exit 0
fi

if [[ ! -d "$PROMPT_DIR" ]]; then
  notify_message "❌ Prompt directory not found" 5000 || true
  echo "Error: prompt directory does not exist: $PROMPT_DIR" >&2
  exit 1
fi

INPUT_TEXT="$(clipboard_read_primary)"

if [[ -z "${INPUT_TEXT//[[:space:]]/}" ]]; then
  notify_message "❌ Primary clipboard is empty" 5000 || true
  echo "Error: primary clipboard is empty." >&2
  exit 1
fi

PROMPT_NAME="$(find "$PROMPT_DIR" -type f -name '*.prompt.md' -printf '%P\n' | \
  sed 's/\.prompt\.md$//' | sort | \
  fzf_menu --reverse \
    --header='Enter: select | Esc: cancel' \
    --preview="cat '$PROMPT_DIR'/{}.prompt.md" \
    --preview-window='right,border-left')" || exit 0

if [[ -z "${PROMPT_NAME:-}" ]]; then
  exit 0
fi

PROMPT_FILE="$PROMPT_DIR/${PROMPT_NAME}.prompt.md"
SYSTEM_PROMPT="$(cat "$PROMPT_FILE")"

# Release lock before the background processing starts.
exec 9>&-

(
  start_spinner "⏳ Processing \"${PROMPT_NAME}\""

  if RESULT="$(llm --system "$SYSTEM_PROMPT" "<text>
$INPUT_TEXT
</text>")"; then
    stop_spinner
    clipboard_paste_via_shift_insert "$RESULT"
    notify_message "✅ Result pasted" 1500 || true
    sleep 1.5
    close_notification
  else
    stop_spinner
    notify_message "❌ LLM processing failed" 5000 || true
    sleep 5
    close_notification
  fi
) </dev/null >/dev/null 2>/dev/null &
disown

exit 0